{
  "architectures": ["LlamaForCausalLM"],
  "model_type": "llama",
  "vocab_size": 16000,
  "hidden_size": 384,
  "intermediate_size": 1024,
  "num_hidden_layers": 8,
  "num_attention_heads": 6,
  "num_key_value_heads": 6,
  "hidden_act": "silu",
  "max_position_embeddings": 1024,
  "initializer_range": 0.02,
  "rms_norm_eps": 1e-5,
  "use_cache": true,
  "tie_word_embeddings": true,
  "rope_theta": 10000.0,
  "attention_bias": false,
  "pretraining_tp": 1,
  "bos_token_id": 1,
  "eos_token_id": 2,
  "pad_token_id": 0
}
